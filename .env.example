# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ADMIN_EMAIL: The administrator email for signing into the recruitment management panel.
# Default: recruitmentluziegroup@gmail.com
ADMIN_EMAIL="recruitmentluziegroup@gmail.com"

# ADMIN_PASSWORD: The plain-text password or bcrypt hash for the admin panel.
ADMIN_PASSWORD="admin_luzie_secure"

# JWT_SECRET: A secret string used to sign session cookies for admin authentication.
JWT_SECRET="luzie_secret_jwt_key_2026"

# GOOGLE_SHEET_ID: The ID of the Google Sheet acting as our primary recruitment database.
GOOGLE_SHEET_ID=""

# GOOGLE_SERVICE_ACCOUNT_KEY: The stringified JSON containing client_email, private_key, etc.,
# obtained from your Google Cloud Console Service Account Key.
GOOGLE_SERVICE_ACCOUNT_KEY=""
